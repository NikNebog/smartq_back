generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────
// ENUMS
// ──────────────────────────────

enum Role {
  admin
  specialist
  manager
}

enum TicketStatus {
  created
  waiting
  called
  in_service
  completed
  cancelled
  no_show
  redirected
}

enum EventType {
  ticket_created
  patient_arrived
  ticket_called
  service_started
  service_completed
  ticket_cancelled
  patient_redirected
  queue_overloaded
}

enum RecommendationSeverity {
  info
  warning
  critical
}

enum PlaceType {
  CABINET
  WINDOW
  TABLE
}

// ──────────────────────────────
// MODELS
// ──────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(specialist)
  roomId    Int?
  room      Room?    @relation(fields: [roomId], references: [id])
  createdAt DateTime @default(now())

  @@map("users")
}

model ServiceType {
  id                      Int      @id @default(autoincrement())
  name                    String   @unique
  averageDurationMinutes  Int
  priorityWeight          Int      @default(1)
  active                  Boolean  @default(true)

  tickets  Ticket[]
  rooms    RoomServiceType[]

  @@map("service_types")
}

model Room {
  id               Int       @id @default(autoincrement())
  name             String    @unique
  isActive         Boolean   @default(true)
  ticketIssueEnabled Boolean @default(true)
  placeType        PlaceType @default(CABINET)
  workingStartTime String?   // формат "HH:MM"
  workingEndTime   String?   // формат "HH:MM"

  tickets       Ticket[]
  users         User[]
  serviceTypes  RoomServiceType[]

  @@map("rooms")
}

// Связующая таблица Room <-> ServiceType
model RoomServiceType {
  roomId        Int
  serviceTypeId Int

  room         Room        @relation(fields: [roomId], references: [id])
  serviceType  ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@id([roomId, serviceTypeId])
  @@map("room_service_types")
}

model Ticket {
  id              Int           @id @default(autoincrement())
  number          String        @unique  // например "A001"
  priority        Int           @default(1)  // 1-5
  isCritical      Boolean       @default(false)
  language        String?       // например "ru", "kk", "en"
  status          TicketStatus  @default(created)
  etaMinutes      Int?          // расчётное время ожидания

  serviceTypeId   Int
  roomId          Int?

  serviceType     ServiceType   @relation(fields: [serviceTypeId], references: [id])
  room            Room?         @relation(fields: [roomId], references: [id])

  createdAt         DateTime   @default(now())
  calledAt          DateTime?
  serviceStartedAt  DateTime?
  completedAt       DateTime?

  events  QueueEvent[]

  @@map("tickets")
}

model QueueEvent {
  id         Int       @id @default(autoincrement())
  ticketId   Int
  eventType  EventType
  oldStatus  TicketStatus?
  newStatus  TicketStatus?
  payload    Json?

  ticket     Ticket    @relation(fields: [ticketId], references: [id])

  createdAt  DateTime  @default(now())

  @@map("queue_events")
}

model QueueRecommendation {
  id          Int                    @id @default(autoincrement())
  type        String
  message     String
  severity    RecommendationSeverity @default(warning)
  isResolved  Boolean                @default(false)
  createdAt   DateTime               @default(now())

  @@map("queue_recommendations")
}

model BoardScreen {
  id        Int      @id @default(autoincrement())
  name      String
  roomNames String[]
  createdAt DateTime @default(now())

  @@map("board_screens")
}

model BoardSettings {
  id        Int      @id @default(1)
  settings  Json
  updatedAt DateTime @updatedAt

  @@map("board_settings")
}

model Terminal {
  id             Int      @id @default(autoincrement())
  name           String
  location       String
  active         Boolean  @default(true)
  roomIds        Int[]    @default([])
  serviceTypeIds Int[]    @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("terminals")
}

// Сюда будут сохраняться название приложения и иконка от админа
model AppSettings {
  id        Int      @id @default(1)
  appName   String   @default("SmartQ")
  appIcon   String   @default("default_icon.png")
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
